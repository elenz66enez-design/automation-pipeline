    {
      "parameters": {
        "method": "GET",
        "url": "https://app.upload-post.com/api/v1/messages/inbox",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "limit",
              "value": "20"
            },
            {
              "name": "unread",
