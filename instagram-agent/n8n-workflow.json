      "id": "a1b2c3d4-0011-0011-0011-000000000011",
      "name": "Get DM Replies (upload-post.com)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        460,
        700
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "UPLOADPOST_API_CRED",
          "name": "upload-post.com API Key"
        }
      }
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "={{ $vars.GOOGLE_SHEET_ID }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "ig_dm_sent",
          "mode": "name"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0012-0012-0012-000000000012",
      "name": "Read Teaser State (Google Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        680,
        700
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CRED",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Find users who: got teaser DM, haven't gotten full DM, now replied\nconst sheetItems = $('Read Teaser State (Google Sheets)').all();\nconst inbox = $('Get DM Replies (upload-post.com)').first().json;\nconst messages = inbox.data || inbox.messages || [];\n\n// Build map: username -> { teaser: bool, full: bool }\nconst userState = {};\nfor (const row of sheetItems) {\n  const u = row.json.username;\n  if (!userState[u]) userState[u] = { teaser: false, full: false };\n  if (row.json.step === 'teaser') userState[u].teaser = true;\n  if (row.json.step === 'full') userState[u].full = true;\n}\n\n// Filter: users who got teaser but NOT full DM, and have a new reply\nconst toProcess = messages\n  .filter(msg => {\n    const u = msg.username || msg.from?.username;\n    const state = userState[u];\n    return state && state.teaser && !state.full;\n  })\n  .map(msg => ({\n    json: {\n      username: msg.username || msg.from?.username || 'du',\n      message_text: msg.text || msg.message || 'ja',\n      message_id: msg.id\n    }\n  }));\n\nif (toProcess.length === 0) {\n  return [{ json: { skip: true } }];\n}\nreturn toProcess;"
      },
      "id": "a1b2c3d4-0013-0013-0013-000000000013",
      "name": "Filter: Teaser Replied, No Full Yet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        700
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "not-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
