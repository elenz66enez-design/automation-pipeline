      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst text = response?.content?.messages?.[0]?.text \n  || response?.text \n  || 'Hier ist dein Link zum Wohlstands Cheat Code.';\n\nreturn [{\n  json: {\n    ...($('Filter: Teaser Replied, No Full Yet').first().json),\n    dm_text: text\n  }\n}];"
      },
