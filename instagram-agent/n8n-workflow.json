      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Schedule: Every 15 min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://app.upload-post.com/api/v1/comments",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "post_id",
              "value": "={{ $vars.INSTAGRAM_POST_ID }}"
            },
            {
              "name": "limit",
              "value": "50"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Get Comments (upload-post.com)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        460,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "UPLOADPOST_API_CRED",
          "name": "upload-post.com API Key"
        }
      }
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "={{ $vars.GOOGLE_SHEET_ID }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "ig_dm_sent",
          "mode": "name"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Read Sent Log (Google Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        680,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CRED",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// \u2500\u2500 Google Sheets OAuth error guard \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// If Sheets auth fails, fall back to empty set so workflow continues\nlet sentIds = new Set();\ntry {\n  const sentItems = $('Read Sent Log (Google Sheets)').all();\n  sentIds = new Set(sentItems.map(item => item.json.comment_id).filter(Boolean));\n} catch (e) {\n  console.log('[WARN] Sheets OAuth failed, continuing without dedup:', e.message);\n}\n\nconst response = $('Get Comments (upload-post.com)').first().json;\nconst comments = response.data || response.comments || [];\nconst KEYWORDS = ['link', 'links', 'info', 'wohlstand', 'cheat', 'gmbh', 'steuern', 'schick', 'senden'];\n\nconst newComments = comments.filter(comment => {\n  const id = comment.id || comment.comment_id;\n  const text = (comment.text || comment.comment_text || '').toLowerCase();\n  const hasKeyword = KEYWORDS.some(kw => text.includes(kw));\n  return !sentIds.has(id) && hasKeyword;\n});\n\nif (newComments.length === 0) return [{ json: { skip: true } }];\n\nreturn newComments.map(comment => ({\n  json: {\n    comment_id: comment.id || comment.comment_id,\n    username: comment.username || comment.from?.username || 'du',\n    comment_text: comment.text || comment.comment_text || '',\n    timestamp: comment.timestamp || new Date().toISOString()\n  }\n}));"
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Filter: New + Keyword Match",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-items",
              "leftValue": "={{ $json.comment_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "IF: New Comment?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://elenz66enez--rabbi-goldsteyn-dm-agent-webhook.modal.run/generate",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "username",
              "value": "={{ $json.username }}"
            },
            {
              "name": "message",
              "value": "={{ $json.comment_text }}"
            },
            {
              "name": "source",
              "value": "comment"
            },
            {
              "name": "step",
              "value": "teaser"
            }
          ]
        },
        "options": {
          "timeout": 35000,
          "retry": {
            "enabled": true,
            "maxTries": 3,
            "waitBetweenTries": 3000
          }
        }
      },
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Generate Teaser DM (Modal AI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1340,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract text from Modal /generate response\n// Response format: { version: 'v2', content: { messages: [{ type: 'text', text: '...' }] } }\nconst response = $input.first().json;\nconst text = response?.content?.messages?.[0]?.text \n  || response?.text \n  || 'Schreib mir kurz \u2014 ich schick dir was Interessantes.';\n\nreturn [{\n  json: {\n    ...($('Filter: New + Keyword Match').first().json),\n    dm_text: text\n  }\n}];"
      },
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Extract Teaser Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://app.upload-post.com/api/v1/messages/dm",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"post_id\": \"{{ $vars.INSTAGRAM_POST_ID }}\",\n  \"username\": \"{{ $json.username }}\",\n  \"message\": \"{{ $json.dm_text }}\"\n}",
        "options": {}
      },
      "id": "a1b2c3d4-0008-0008-0008-000000000008",
      "name": "Send Teaser DM (upload-post.com)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1780,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "UPLOADPOST_API_CRED",
          "name": "upload-post.com API Key"
        }
      }
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "={{ $vars.GOOGLE_SHEET_ID }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "ig_dm_sent",
          "mode": "name"
